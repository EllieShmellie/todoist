# Docker Compose project settings. Copy this file to `.env` before startup.
COMPOSE_PROJECT_NAME=todoist

BACKEND_PORT=8000
FRONTEND_PORT=3000

APP_ENV=local
APP_DEBUG=true
# Optional. Leave blank for Docker to generate an ephemeral Laravel key.
APP_KEY=
LOG_LEVEL=debug

# Seeds are applied only when the SQLite volume is created for the first time.
SEED_DATABASE=true

# This URL is used by the browser, so it must be reachable from the host.
NUXT_PUBLIC_API_BASE=http://localhost:8000/api
